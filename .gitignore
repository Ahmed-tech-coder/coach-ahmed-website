# ==========================================
# Coach Ahmed Website - .gitignore
# Production-ready Git ignore configurations
# ==========================================

# ------------------------------------------
# Dependencies
# ------------------------------------------
# Ignore node packages and package manager cache
node_modules/
jspm_packages/
.npm/
.eslintcache

# ------------------------------------------
# Build & Output
# ------------------------------------------
# Vite default build folder
dist/
dist-ssr/
*.local

# Vercel deployment metadata
.vercel/

# ------------------------------------------
# Environment Variables & Secrets
# ------------------------------------------
# Crucial: Never commit API keys, secrets, or local env configurations
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ------------------------------------------
# Debug & Logs
# ------------------------------------------
# Log files generated by node/npm/yarn/bun
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*
*.log

# ------------------------------------------
# Editor & IDE Configs
# ------------------------------------------
# IDE-specific configurations (VS Code, WebStorm, etc.)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvsca*
*.njsproj
*.sln
*.sw?

# ------------------------------------------
# System & OS Files
# ------------------------------------------
# OS-specific files (macOS / Windows desktop artifacts)
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------
# Testing & Coverage
# ------------------------------------------
# Coverage directories for test environments
coverage/
*.lcov
.nyc_output/
